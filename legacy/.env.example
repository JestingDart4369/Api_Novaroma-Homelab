# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARACTERS

# ============================================================
# ROLE LIMITS (requests per hour per role)
# ============================================================
ROLE_USER_MAX_CALLS=1000
ROLE_ADMIN_MAX_CALLS=2000
ROLE_SUPERADMIN_MAX_CALLS=5000
ROLE_ROOT_MAX_CALLS=10000

# ============================================================
# API: OpenWeather (current weather + forecasts)
# ============================================================
OPENWEATHER_KEY=YOUR_OPENWEATHER_API_KEY
OPENWEATHER_ENABLED=true
OPENWEATHER_MAX_CALLS=3000

# ============================================================
# API: Geoapify (geocoding)
# ============================================================
GEOAPIFY_KEY=YOUR_GEOAPIFY_API_KEY
GEOAPIFY_ENABLED=true
GEOAPIFY_MAX_CALLS=5000

# ============================================================
# API: IPRegistry (IP geolocation)
# ============================================================
IPREGISTRY_KEY=YOUR_IPREGISTRY_API_KEY
IPREGISTRY_ENABLED=true
IPREGISTRY_MAX_CALLS=10000

# ============================================================
# API: Resend (email)
# ============================================================
RESEND_KEY=YOUR_RESEND_API_KEY
RESEND_ENABLED=true
RESEND_MAX_CALLS=100

# ============================================================
# API: Telephone (search.ch Swiss directory)
# ============================================================
TELEPHONE_KEY=YOUR_SEARCH_CH_API_KEY
TELEPHONE_ENABLED=true
TELEPHONE_MAX_CALLS=1000

# ============================================================
# API: NASA (APOD + EPIC)
# ============================================================
NASA_KEY=DEMO_KEY
NASA_ENABLED=true
NASA_MAX_CALLS=900

# ============================================================
# API: Open Library (books + Internet Archive S3)
# ============================================================
OPENLIBRARY_KEY=YOUR_S3_ACCESS_KEY
OPENLIBRARY_SECRET=YOUR_S3_SECRET_KEY
OPENLIBRARY_ENABLED=true
OPENLIBRARY_MAX_CALLS=5000

# ============================================================
# API: Pushcut (iOS automation & notifications)
# ============================================================
PUSHCUT_KEY=YOUR_PUSHCUT_API_KEY
PUSHCUT_ENABLED=true
PUSHCUT_MAX_CALLS=1000

# ============================================================
# API: Grade (https://api.sercraft.ch) - no API key required
# ============================================================
GRADE_ENABLED=true
GRADE_MAX_CALLS=1000

# ============================================================
# Email configuration (server notifications + client emails)
# ============================================================
DEFAULT_FROM_EMAIL=App <app@yourdomain.com>
SERVER_FROM_EMAIL=API Server <apiserver@yourdomain.com>
ADMIN_EMAIL=admin@yourdomain.com
EMAIL_DOMAIN=yourdomain.com          # Domain for RECIPIENTS (to_users in /email/send-simple)
SENDER_DOMAIN=api.yourdomain.com     # Domain for SENDERS (from_email - must be verified in Resend)

# ============================================================
# Bootstrap Root user (one-time auto-create if no users exist)
# ============================================================
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisPasswordImmediately

# ============================================================
# Cloudflare Tunnel (optional - for public access)
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=PASTE_YOUR_TUNNEL_TOKEN_HERE
